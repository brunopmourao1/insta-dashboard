# ══════════════════════════════════════════════════════════════
# Gestão da Jaque — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com seus valores reais.
# O .env NUNCA deve ser commitado (já está no .gitignore).
# ══════════════════════════════════════════════════════════════

# ── Neon (PostgreSQL Serverless) ──────────────────────────────
# Connection string completa do Neon (painel: Dashboard → Connection Details)
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# ── Meta / Instagram Graph API ────────────────────────────────
# Obtidos em: https://developers.facebook.com → Seu App → Configurações
META_APP_ID=
META_APP_SECRET=

# ── Frontend (expostas ao navegador — prefixo VITE_) ──────────
# URL base da API (quando tiver backend/serverless functions)
VITE_API_URL=http://localhost:3001/api
